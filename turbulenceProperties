/*--------------------------------*- C++ -*----------------------------------*\
| OpenFOAM From Scratch — Episode 10 | Turbulence Modeling                     |
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// This is the file that tells OpenFOAM HOW to treat turbulence.
//   simulationType  laminar  -> no model (what the cavity used)
//   simulationType  RAS      -> Reynolds-Averaged (this episode)
//   simulationType  LES      -> Large Eddy Simulation

simulationType  RAS;

RAS
{
    // The model itself. kOmegaSST is the modern workhorse for external
    // flows and anything with separation — exactly the pitzDaily step.
    // Swap to kEpsilon to feel the difference in the free stream.
    RASModel        kOmegaSST;

    // turbulence on = actually apply the model. off = freeze it.
    turbulence      on;

    // print model coefficients to the log at start-up (handy while learning)
    printCoeffs     on;
}

// ************************************************************************* //
