/*--------------------------------*- C++ -*----------------------------------*\
| OpenFOAM From Scratch — Episode 10 | Turbulence Modeling                     |
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// omega = specific dissipation rate (how fast k is destroyed).
// Units: 1/s -> [0 0 -1 0 0 0 0].  Estimated as omega = sqrt(k) / (Cmu^0.25 * L)
// with a mixing length L ~ a few mm for this small channel.

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 4.5;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 4.5;
    }
    outlet
    {
        type            zeroGradient;
    }
    upperWall
    {
        // wall function for omega — the SST near-wall treatment
        type            omegaWallFunction;
        value           uniform 4.5;
    }
    lowerWall
    {
        type            omegaWallFunction;
        value           uniform 4.5;
    }
    frontAndBack
    {
        type            empty;
    }
}

// ************************************************************************* //
